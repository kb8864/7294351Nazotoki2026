# ============================================================
#  環境変数（.env.local にコピーして設定）
# ============================================================

# --- LINE / LIFF ---
# LINE Developers コンソールで作成した LIFF ID
# https://developers.line.biz/console/
NEXT_PUBLIC_LIFF_ID=0000000000-xxxxxxxx
# 上記 LIFF が属する「LINEログインチャネル」のチャネルID（IDトークン検証に使用）
LINE_CHANNEL_ID=0000000000

# --- Redis（Vercel Marketplace の Redis を Connect すると自動投入される）---
# TCP 接続文字列（node-redis で接続）。例: redis://... または rediss://...
REDIS_URL=redis://default:xxxxx@xxxxx:6379

# --- 管理用集計エンドポイントの保護キー（任意・自分で決める）---
# /api/admin/stats?key=<ADMIN_KEY> で全問正解者数などを確認できる
ADMIN_KEY=set-your-own-secret

# 補足:
# - REDIS_URL が未設定でも `npm run dev` は動作します（メモリ内ストア＋開発ユーザー）。
#   ただしデータは永続化されず、サーバー再起動で消えます。
# - 本番(Vercel)では REDIS_URL（Marketplace の Redis 接続で自動設定）が必須です。
